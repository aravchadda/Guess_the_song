# ── Frontend environment variables ──
# Copy to `.env.local` (gitignored) and fill in per environment.
# NEXT_PUBLIC_* values are inlined into the client bundle at build time.

# Backend base URL
#   Local:      http://localhost:4000
#   Production: https://api.replays.in   (or wherever the backend is hosted)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google OAuth Client ID for the "Sign in with Google" button.
# Use the DEV client locally and the PROD client on the server.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=103998945467-3e3ghetqb4m5b4d6pvauhmsva7ltr902.apps.googleusercontent.com
