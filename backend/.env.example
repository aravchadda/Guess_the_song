# ── Backend environment variables ──
# Copy to `.env` (gitignored) and fill in per environment.

PORT=4000
MONGODB_URI=mongodb://localhost:27017/guess-the-song

# Comma-separated allowed origins for CORS.
#   Local:      http://localhost:3000
#   Production: https://replays.in
# You can list multiple: http://localhost:3000,https://replays.in
CORS_ORIGIN=http://localhost:3000

# Absolute path to the preprocessed audio dir (defaults to backend/preprocessed if unset)
AUDIO_PATH=

# Fuzzy guess-match strictness (0..1)
MATCH_THRESHOLD=0.72

# ── Auth ──
# Google OAuth Client ID used to VERIFY ID tokens.
# Use the DEV client locally and the PROD client on the server (two separate clients).
GOOGLE_CLIENT_ID=103998945467-3e3ghetqb4m5b4d6pvauhmsva7ltr902.apps.googleusercontent.com

# Secret used to sign app session JWTs. MUST be a long random string in production.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
